<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.ActivityTypeMapper">
    
    <resultMap type="ActivityType" id="ActivityTypeResult">
        <result property="id"    column="id"    />
        <result property="name"    column="name"    />
        <result property="tag"    column="tag"    />
        <result property="orderNum"    column="order_num"    />
        <result property="createTime"    column="create_time"    />
    </resultMap>

    <sql id="selectActivityTypeVo">
        select id, name, tag, order_num, create_time from activity_type
    </sql>

    <select id="selectActivityTypeList" parameterType="ActivityType" resultMap="ActivityTypeResult">
        <include refid="selectActivityTypeVo"/>
        <where>  
            <if test="name != null  and name != ''"> and name like concat('%', #{name}, '%')</if>
            <if test="tag != null  and tag != ''"> and tag = #{tag}</if>
            <if test="orderNum != null "> and order_num = #{orderNum}</if>
        </where>
        order by order_num asc
    </select>
    
    <select id="selectActivityTypeById" parameterType="Long" resultMap="ActivityTypeResult">
        <include refid="selectActivityTypeVo"/>
        where id = #{id}
    </select>

    <insert id="insertActivityType" parameterType="ActivityType" useGeneratedKeys="true" keyProperty="id">
        insert into activity_type
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="name != null">name,</if>
            <if test="tag != null">tag,</if>
            <if test="orderNum != null">order_num,</if>
            <if test="createTime != null">create_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="name != null">#{name},</if>
            <if test="tag != null">#{tag},</if>
            <if test="orderNum != null">#{orderNum},</if>
            <if test="createTime != null">#{createTime},</if>
         </trim>
    </insert>

    <update id="updateActivityType" parameterType="ActivityType">
        update activity_type
        <trim prefix="SET" suffixOverrides=",">
            <if test="name != null">name = #{name},</if>
            <if test="tag != null">tag = #{tag},</if>
            <if test="orderNum != null">order_num = #{orderNum},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteActivityTypeById" parameterType="Long">
        delete from activity_type where id = #{id}
    </delete>

    <delete id="deleteActivityTypeByIds" parameterType="String">
        delete from activity_type where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>