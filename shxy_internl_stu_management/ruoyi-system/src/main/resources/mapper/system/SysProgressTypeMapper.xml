<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.SysProgressTypeMapper">
    
    <resultMap type="SysProgressType" id="SysProgressTypeResult">
        <result property="id"    column="id"    />
        <result property="name"    column="name"    />
        <result property="createTime"    column="create_time"    />
    </resultMap>

    <sql id="selectSysProgressTypeVo">
        select id, name, create_time from sys_progress_type
    </sql>

    <select id="selectSysProgressTypeList" parameterType="SysProgressType" resultMap="SysProgressTypeResult">
        <include refid="selectSysProgressTypeVo"/>
        <where>  
            <if test="name != null  and name != ''"> and name like concat('%', #{name}, '%')</if>
        </where>
    </select>
    
    <select id="selectSysProgressTypeById" parameterType="Long" resultMap="SysProgressTypeResult">
        <include refid="selectSysProgressTypeVo"/>
        where id = #{id}
    </select>

    <insert id="insertSysProgressType" parameterType="SysProgressType" useGeneratedKeys="true" keyProperty="id">
        insert into sys_progress_type
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="name != null">name,</if>
            <if test="createTime != null">create_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="name != null">#{name},</if>
            <if test="createTime != null">#{createTime},</if>
         </trim>
    </insert>

    <update id="updateSysProgressType" parameterType="SysProgressType">
        update sys_progress_type
        <trim prefix="SET" suffixOverrides=",">
            <if test="name != null">name = #{name},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteSysProgressTypeById" parameterType="Long">
        delete from sys_progress_type where id = #{id}
    </delete>

    <delete id="deleteSysProgressTypeByIds" parameterType="String">
        delete from sys_progress_type where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>