file_type": "application/vnd.openxmlformats-officedocument.wordprocessingml.document", "file_size": 40231, "creation_date": "2026-03-12", "last_modified_date": "2026-03-12", "source_file": "\u653b\u7565\uff5cUMN\u65b0\u751f\u7b7e\u8bc1\u7533\u8bf7\u6307\u5357.docx", "import_time": "2026-03-12T02:04:46.744414"}, "hash": "ebffde23b293472380d3fc24804c7dd56d80a58283316afe51aa06b334b6f506", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "b36fc60e-3992-483e-8c34-895c4a792e86", "node_type": "1", "metadata": {}, "hash": "32455b6746ae0c02b93165d15ae80d05dedf5e3d52857f6d31a1dec81bb80058", "class_name": "RelatedNodeInfo"}}, "text": "\u653b\u7565\uff5cUMN\u65b0\u751f\u7b7e\u8bc1\u7533\u8bf7\u6307\u5357\n\n\u7b7e\u8bc1\u7533\u8bf7\u6307\u5357\n\n#WELCOME TO University of Minnesota\n\n#CHINESE UNION Non-Profit \u00b7 2005-2025\n\n\u4eb2\u7231\u7684\u672a\u6765Trojan\u6210\u5458\uff1a\n\n\u795d\u8d3a\u4f60\u6b63\u5f0f\u52a0\u5165\u660e\u5c3c\u82cf\u8fbe\u5927\u5b66\u53cc\u57ce\u5206\u6821\uff08UMN\uff09\u8fd9\u4e2a\u5145\u6ee1\u6d3b\u529b\u4e0e\u673a\u9047\u7684\u5927\u5bb6\u5ead\uff01CU UMN\u7ed3\u5408\u5b98\u65b9\u653f\u7b56\u4e0e\u5f80\u5c4a\u5b66\u751f\u7ecf\u9a8c\uff0c\u4e3a\u4f60\u7cbe\u5fc3\u68b3\u7406\u4e86\u8fd9\u4efd\u300c\u7b7e\u8bc1\u7533\u8bf7\u6307\u5357\u300d\uff0c\u52a9\u529b\u4f60\u4e1d\u6ed1\u8fc7\u7b7e\uff0c\u987a\u5229\u5f00\u542f\u5b66\u672f\u63a2\u7d22\u4e0e\u4e2a\u4eba\u6210\u957f\u7684\u65b0\u7bc7\u7ae0\uff01\n\n\u4ec0\u4e48\u662fI-20\u8868\u683c\n\nI-20\u8868\u683c\u662f\u6bcf\u4e2a\n\n\u524d\u5f80\u7f8e\u56fd\u63a5\u53d7\u6559\u80b2\u5e76\u5728\u7f8e\u56fd\u62e5\u6709\u5408\u6cd5\u505c\u7559\u6743\u5229\n\n\u7684\u5b66\u751f\uff08\u5373F-1\u5b66\u751f\u7b7e\u8bc1\u8005\uff09\u6240\u9700\u7684\u91cd\u8981\u6587\u4ef6\u4e4b\u4e00\u3002\u5b83\u7531\n\n\u7f8e\u56fd\u79fb\u6c11\u5c40\n\n\u7b7e\u53d1\uff0c\u662f\u7533\u8bf7\n\nF-1\u5b66\u751f\u7b7e\u8bc1\n\n\u65f6\u6240\n\n\u5fc5\u987b\u7684\u6587\u4ef6\n\n\u4e5f\u5c31\u662f\u8bf4\uff0c\u5728\u83b7\u5f97\u4e86I-20\u8868\u683c\u540e\uff0c29\u5c4a\u7684\u65b0\u751f\u4eec\u5c31\u53ef\u4ee5\u5f00\u59cb\u51c6\u5907\u7b7e\u8bc1\u76f8\u5173\u7684\u7533\u8bf7\u6750\u6599\u5566\uff01\n\nI-20 Sample\n\nStep1:\n\n\u7533\u8bf7I-20\u8868\u683c\n\nUMN\u4f1a\u5728\u786e\u8ba4\u5f55\u53d6\u540e\n\n7-10\u4e2a\u5de5\u4f5c\u65e5\n\n\u5185\u901a\u8fc7\u7535\u5b50\u90ae\u4ef6\u53d1\u9001I-20\u8868\u683c\u3002\u9700\u4ed4\u7ec6\u6838\u5bf9\u59d3\u540d\u3001\u51fa\u751f\u65e5\u671f\u3001\u56fd\u7c4d\u7b49\u4fe1\u606f\uff0c\u5982\u6709\u9519\u8bef\u9700\u7acb\u5373\u8054\u7cfb\u5b66\u6821\u66f4\u6539\n\n\u5728I-20\u7b2c\u4e00\u9875\u4e2d\u7684Student Attestation\u90e8\u5206\n\n\u7b7e\u540d\u5e76\u6ce8\u660e\u65e5\u671f\n\n\uff0c\u7528\u4e8e\u968f\u540e\u7684\u7b7e\u8bc1\u7533\u8bf7\n\n\u5982\u679c\u8eab\u5904\u7f8e\u56fd\u5883\u5185 \u8bf7\u8bb0\u5f97\u63d0\u4f9b\n\nI-94\u8868\u683c\u51fa\u5165\u5883\u8bc1\u660e\n\n\u67e5\u8be2\u94fe\u63a5\uff1a\n\nhttps://i94.cbp.dhs.gov/search/recent-search\n\nStep2:\n\n\u652f\u4ed8SEVIS\u8d39\u7528&\n\n\u586b\u5199DS-160\n\n\u5728\u7ebf\u652f\u4ed8\n\nI-901 SEVIS\u8d39\u7528\n\n\uff08350\u7f8e\u5143\uff09\uff0c\u5e76\u4fdd\u7559\u6536\u636e\u4f5c\u4e3a\u9762\u7b7e\u6750\u6599\n\nSEVIS\u8d39\u7528\u652f\u4ed8\u94fe\u63a5\uff1a\n\nhttps://www.fmjfee.com/i901fee/index.html\n\n\u7f51\u9875\u5185\u6240\u9700\u8981\u586b\u5199\u7684\u767b\u9646\u4fe1\u606f\u5747\u53ef\u4ee5\u5728I-20\u8868\u683c\u4e0a\u627e\u5230\n\n\u586b\u5199\n\nDS-160\u8868\u683c\n\n\uff0c\u9884\u7ea6F-1\u5b66\u751f\u7b7e\u8bc1\u9762\u8c08\u3002\u9762\u7b7e\u9700\u643a\u5e26\u62a4\u7167\u3001I-20\u3001\u5f55\u53d6\u901a\u77e5\u4e66\u3001\u8d44\u91d1\u8bc1\u660e\u7b49\u6750\u6599\uff0c\u90e8\u5206\u60c5\u51b5\u4e0b\u8fd8\u9700\u63d0\u4f9b\u6210\u7ee9\u5355\u3001\u6807\u51c6\u5316\u8003\u8bd5\u6210\u7ee9\u7b49\u3002\n\n\u5728\u586b\u5199\u5b8c\u6bd5\u540e \u8bf7\u4e00\u5b9a\u8bb0\u5f97\u4fdd\u5b58\u786e\u8ba4\u9875\u9762\u4ee5\u53caApplication ID\uff0cDS-160\u8868\u683c\u4f1a\u5728\u968f\u540e\u7684\u7f8e\u56fd\u5f53\u9762\u7b7e\u8bc1\u4e2d\u88ab\u4f7f\u7528\n\n\u586b\u5199\u94fe\u63a5\uff1a\n\nhttps://travel.state.gov/content/travel/en/us-visas/visa-information-resources/forms/ds-160-online-nonimmigrant-visa-application.html\n\n\u6ce8\u610f\uff1a\n\n\u6700\u65e9\u53ef\u5728\u5f00\u8bfe\u524d 120 \u5929\u5185\u5f00\u59cb\u9884\u7ea6\u9762\u7b7e \uff1b\n\n\u7b7e\u8bc1\u83b7\u6279\u540e\uff0c\u5165\u5883\u4e0d\u5f97\u65e9\u4e8e\u5f00\u8bfe\u524d 30 \u5929\n\nStep3:\n\n\u9884\u7ea6\u5f53\u9762\u7b7e\u8bc1\n\n\u524d\u5f80US Travel Docs \u5e73\u53f0\uff08portal.ustraveldocs.com\uff09\u5b8c\u6210\u6ce8\u518c\u3001\u652f\u4ed8\u53ca\u9884\u7ea6\u9762\u7b7e\n\n\u9884\u7ea6\u9762\u7b7e\u7f51\u5740\u94fe\u63a5\uff1a\n\nhttps://portal.ustraveldocs.", "mimetype": "text/plain", "start_char_idx": 0, "end_char_idx": 1209, "text_template": "{metadata_str}\n\n{content}", "metadata_template": "{key}: {value}", "metadata_seperator": "\n", "class_name": "TextNode"}, "__type__": "1"}, "b36fc60e-3992-483e-8c34-895c4a792e86": {"__data__": {"id_": "b36fc60e-3992-483e-8c34-895c4a792e86", "embedding": null, "metadata": {"file_name": "\u653b\u7565\uff5cUMN\u65b0\u751f\u7b7e\u8bc1\u7533\u8bf7\u6307\u5357.docx", "file_path": "E:\\\u5de5\u4f5c\u9879\u76ee\\\u897f\u67da\\school_data\\UMN\\\u653b\u7565\uff5cUMN\u65b0\u751f\u7b7e\u8bc1\u7533\u8bf7\u6307\u5357.docx", "file_type": "application/vnd.openxmlformats-officedocument.wordprocessingml.document", "file_size": 40231, "creation_date": "2026-03-12", "last_modified_date": "2026-03-12", "source_file": "\u653b\u7565\uff5cUMN\u65b0\u751f\u7b7e\u8bc1\u7533\u8bf7\u6307\u5357.docx", "import_time": "2026-03-12T02:04:46.744414"}, "excluded_embed_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "excluded_llm_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "relationships": {"1": {"node_id": "272b4872-d6df-4